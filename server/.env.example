# --- Required ---
# Secret used to sign login tokens. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Public URL of the frontend (GitHub Pages), used to build invite links.
APP_URL=https://fritscherman.github.io/postcards

# Allowed browser origin(s) for CORS — your Pages origin. Comma-separated, or * while testing.
ALLOWED_ORIGIN=https://fritscherman.github.io

# Port the server listens on.
PORT=8787

# Where the SQLite file lives (put this on a persistent volume in production).
DB_PATH=./data/postcards.db

# --- Optional: email invites via SMTP (leave empty to only use invite links) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=postkarten@example.com
# SMTP_PASS=your-smtp-password
# INVITE_FROM=Postkarten <postkarten@example.com>
