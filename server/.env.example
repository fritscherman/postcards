# Copy this file to server/.env and fill it in. Never commit server/.env.

# --- Required ---
# Secret used to sign login tokens. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Public URL of the app (your subdomain). Used to build invite links.
APP_URL=https://postkarten.deinedomain.de

# Port the Node process listens on (your reverse proxy / subdomain points here).
PORT=8787

# Where the SQLite file lives. Relative to the server/ folder by default.
DB_PATH=./data/postcards.db

# --- Optional ---
# Allowed browser origin(s) for CORS. Same-origin needs nothing; leave * unless
# you split frontend and backend onto different hosts.
ALLOWED_ORIGIN=*

# Override where the built frontend is served from (defaults to ../dist).
# STATIC_DIR=../dist

# --- Optional: Push-Benachrichtigungen (Web Push) ---
# Erzeuge ein Schlüsselpaar einmalig mit:  npm run generate-vapid  (im server/-Ordner)
# und trage die Ausgabe hier ein. Ohne diese Werte ist Push einfach deaktiviert
# (die App funktioniert ansonsten normal weiter).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Kontaktadresse für die Push-Dienste (mailto: oder eine https-URL).
# VAPID_SUBJECT=mailto:du@deinedomain.de

# --- Optional: email invites via SMTP (leave empty to only share invite links) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=postkarten@example.com
# SMTP_PASS=your-smtp-password
# INVITE_FROM=Postkarten <postkarten@example.com>
