{
  "name": "postcards-server",
  "private": true,
  "version": "1.0.0",
  "description": "Node/Express + SQLite backend for the Postkarten app",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "generate-vapid": "node -e \"const w=require('web-push').generateVAPIDKeys();console.log('VAPID_PUBLIC_KEY='+w.publicKey);console.log('VAPID_PRIVATE_KEY='+w.privateKey)\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "node-sqlite3-wasm": "^0.8.58",
    "nodemailer": "^6.10.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.1",
    "@types/nodemailer": "^6.4.17",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
